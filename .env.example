# HydraDB is a remote context service. Only set a key after reviewing docs/PRIVACY.md.
HYDRA_DB_API_KEY=
HYDRA_DATABASE=hydra_mlx_context
HYDRA_COLLECTION=local_user

# LM Studio defaults to 1234; mlx_lm.server commonly uses 8080.
LOCAL_LLM_BASE_URL=http://127.0.0.1:1234/v1
LOCAL_LLM_MODEL=local-model
LOCAL_LLM_API_KEY=lm-studio
